<Window x:Class="MainReportDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Title="Главный отчёт" Height="700" Width="800" WindowStartupLocation="CenterScreen" >
    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="reportDateMonth" FontWeight="Bold" FontSize="12" HorizontalAlignment="Left" Margin="10,0,0,0"
                   Text="{Binding ReportDateTime}" VerticalAlignment="Center" Width="70" Height="20"/>
        <TextBlock x:Name ="reportDateYear" FontWeight="Bold" FontSize="12" HorizontalAlignment="Left" Margin="85,0,0,0"
                   Text="{Binding ReportDateYear}" VerticalAlignment="Center" Width="70" Height="20"/>

        <Button Content="Вычислить" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,0,0,0" Width="70" ToolTip="Сделать расчет сервисной деятельности" Click="Count" Grid.Row="6" Height="20" VerticalAlignment="Center"/>


        <TabControl x:Name="MainReportTab" Margin="10,10,10,10" Grid.ColumnSpan="2" Grid.Row="4" Grid.RowSpan="2">
            <TabItem x:Name="requestsTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="3">Запросы</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <StackPanel>
                        <ListView x:Name="reportListView" BorderBrush="CornflowerBlue" HorizontalContentAlignment="Stretch" 
                  VerticalContentAlignment="Stretch" FontSize="12" FontFamily="Calibri" BorderThickness="2,2,2,2" 
                  IsTextSearchEnabled="False" Margin="10,10,10,10" Focusable="False" Height="260">
                            <ListView.View>
                                <GridView>

                                    <GridViewColumn Header="Статус" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <RadioButton IsHitTestVisible="False" Background="{Binding Color}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Сервисный контракт" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ContractName}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Кол-во обращений" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ReportAmount}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="КИ" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Critical}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="SLA" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SLAMonth}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="ЗнД" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RequestsAccess}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="ЗнИ" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RequestsChange}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="ЗнО" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RequestsUsage}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Инц." Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Incidents}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Инц. ИБ" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding IncidentsIS}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Консультация" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RequestsAdvice}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="ППР" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PlanedWork}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </TabItem.Content>
            </TabItem>

            <TabItem x:Name="slaTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="3">SLA</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <StackPanel>
                        <ListView x:Name="slaListView" BorderBrush="CornflowerBlue" HorizontalContentAlignment="Stretch" 
                  VerticalContentAlignment="Stretch" FontSize="12" FontFamily="Calibri" BorderThickness="2,2,2,2" 
                  IsTextSearchEnabled="False" Margin="10,10,10,10" Focusable="False" Height="260">
                            <ListView.View>
                                <GridView>

                                    <GridViewColumn Header="Статус" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <RadioButton IsHitTestVisible="False" Background="{Binding ColorYear}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Сервисный контракт" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ContractName}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Кол-во обращений" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ReportAmountYear}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="КИ" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding CriticalYear}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="SLA месяц" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SLAMonth}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="SLA квартал" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SLAQuarter}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="SLA год" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SLAYear}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="ППР" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PlanedWork}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="5" Width="Auto" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Five}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="4" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Four}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="3" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Three}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="2" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Two}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="-" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding NoMark}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="↺" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Restart}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </TabItem.Content>
            </TabItem>

            <TabItem x:Name="crisisTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="3">Диаграмма</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <StackPanel>
                        <lvc:CartesianChart Name="graphSLA" DisableAnimations="True" LegendLocation="None" Grid.ColumnSpan="2" Grid.Row="4" Grid.RowSpan="2" Margin="10,10,10,10" Height="270">

                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Foreground="Gray">
                                    <lvc:Axis.Sections>
                                        <lvc:AxisSection/>
                                    </lvc:Axis.Sections>
                                </lvc:Axis>
                                <lvc:Axis Foreground="DarkBlue" Position="RightTop">
                                    <lvc:Axis.Sections>
                                        <lvc:AxisSection/>
                                    </lvc:Axis.Sections>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>

                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis>
                                    <lvc:Axis.Sections>
                                        <lvc:AxisSection/>
                                    </lvc:Axis.Sections>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>

                        </lvc:CartesianChart>
                    </StackPanel>
                </TabItem.Content>
            </TabItem>

            <TabItem x:Name="incidentsTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="3">КИ</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <StackPanel>
                        <ListView x:Name="crisisListView" BorderBrush="CornflowerBlue" HorizontalContentAlignment="Stretch" 
                  VerticalContentAlignment="Stretch" FontSize="12" FontFamily="Calibri" BorderThickness="2,2,2,2" 
                  IsTextSearchEnabled="False" Margin="10,10,10,10" Focusable="False" Height="240">
                            <ListView.View>
                                <GridView>

                                    <GridViewColumn Header="Учёт" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox Checked="Check" Unchecked="UnCheck" IsChecked="{Binding Check}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Номер заявки" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RegNum}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    
                                    <GridViewColumn Header="Сервисный контракт" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ContractName}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Статус" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Сервис" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ServiceName}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Описание" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" Margin="0 10 30 0" TextWrapping="NoWrap" TextAlignment="Center" Foreground="Black"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>
                        </ListView>
                        <Button Content="Обновить" ToolTip="Обновить данные расчета" Height="20" Width="68" Click="Reload"/>
                    </StackPanel>
                </TabItem.Content>
            </TabItem>

        </TabControl>

        <Button Content="Добавить" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="3" ToolTip="Добавить наименование контракта в список контрактов" VerticalAlignment="Center" Height="20" Width="68" Click="Add" Grid.Column="1"/>
        <Button Content="Удалить" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="3" ToolTip="Удалить выбранные контракты из списка контрактов" VerticalAlignment="Center" Height="20" Width="68" Click="Delete"/>


        <ListView Grid.Row="2" x:Name="contractsListView" BorderBrush="CornflowerBlue" HorizontalContentAlignment="Stretch" 
                  VerticalContentAlignment="Stretch" FontSize="12" FontFamily="Calibri" BorderThickness="2,2,2,2" 
                  IsTextSearchEnabled="False" Margin="10,10,10,10" Focusable="False">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название контракта" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Text="Список сервисных контрактов" FontWeight="Bold" VerticalAlignment="Center" Height="20" Margin="10,0,200,0"/>
        <ListView x:Name="deletedContractsListView" Grid.Column="1" Grid.Row="2" BorderBrush="CornflowerBlue" HorizontalContentAlignment="Stretch" 
                  VerticalContentAlignment="Stretch" FontSize="12" FontFamily="Calibri" BorderThickness="2,2,2,2" 
                  IsTextSearchEnabled="False" Margin="10,10,10,10" Focusable="False">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название контракта" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Text="Достуные сервисные контракты" FontWeight="Bold" VerticalAlignment="Center" Height="20" Margin="10,0,186,0" Grid.Column="1"/>
        <Button Grid.Column="1" Content="Выгрузить" ToolTip="Выгрузить данные в файл" Margin="0,0,10,0" Grid.Row="6" VerticalAlignment="Center" Height="20" HorizontalAlignment="Right" Width="68" Click="Export"/>
        <Button Content="Файл ЦДС" ToolTip="Загрузить оценки ЦДС" HorizontalAlignment="Left" Margin="85,0,0,0" Grid.Row="6" VerticalAlignment="Center" Width="68" Height="20" Click="LoadFile"/>
        <TextBox x:Name="txtBoxFilePath" IsEnabled="False" Margin="158,0,200,0" Grid.Row="6" TextWrapping="Wrap" Text="Выберете файл с оценками ЦДС" VerticalAlignment="Center" Height="20" Grid.ColumnSpan="2"/>
    </Grid>
</Window>
